@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar">
        <div class="brand">
            <span class="brand-mark">
                <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="5" rx="1.5" />
                    <rect x="3" y="10.5" width="18" height="5" rx="1.5" opacity=".75" />
                    <rect x="3" y="18" width="18" height="3" rx="1.5" opacity=".45" />
                </svg>
            </span>
            <span class="brand-text">
                <strong>BlazorVirtualize</strong>
                <span>Demo</span>
            </span>
        </div>

        <div class="nav-label">Demos</div>
        <nav class="nav">
            <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                <span class="ico">@HomeIcon</span> Overview
            </NavLink>
            <NavLink class="nav-item" href="fixed">
                <span class="ico">@ListIcon</span> Fixed size
            </NavLink>
            <NavLink class="nav-item" href="dynamic">
                <span class="ico">@DynamicIcon</span> Dynamic height
            </NavLink>
            <NavLink class="nav-item" href="provider">
                <span class="ico">@CloudIcon</span> Lazy loading
            </NavLink>
            <NavLink class="nav-item" href="infinite">
                <span class="ico">@InfiniteIcon</span> Infinite scroll
            </NavLink>
            <NavLink class="nav-item" href="grouped">
                <span class="ico">@GroupIcon</span> Sticky headers
            </NavLink>
            <NavLink class="nav-item" href="chat">
                <span class="ico">@ChatIcon</span> Chat / reverse
            </NavLink>
            <NavLink class="nav-item" href="horizontal">
                <span class="ico">@HorizontalIcon</span> Horizontal
            </NavLink>
        </nav>

        <div class="sidebar-footer">
            Native windowing for Blazor - O(log n) dynamic sizing &amp; scroll anchoring.
        </div>
    </aside>

    <main class="main">
        <div class="content">
            @Body
        </div>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private static readonly MarkupString HomeIcon = Svg("<path d='M3 9.5 12 3l9 6.5'/><path d='M5 9v11h14V9'/>");
    private static readonly MarkupString ListIcon = Svg("<line x1='8' y1='6' x2='21' y2='6'/><line x1='8' y1='12' x2='21' y2='12'/><line x1='8' y1='18' x2='21' y2='18'/><circle cx='3.5' cy='6' r='1.2'/><circle cx='3.5' cy='12' r='1.2'/><circle cx='3.5' cy='18' r='1.2'/>");
    private static readonly MarkupString DynamicIcon = Svg("<rect x='3' y='4' width='18' height='4' rx='1'/><rect x='3' y='10' width='18' height='7' rx='1'/><rect x='3' y='19' width='18' height='2' rx='1'/>");
    private static readonly MarkupString CloudIcon = Svg("<path d='M17.5 19a4.5 4.5 0 0 0 0-9 6 6 0 0 0-11.6 1.8A3.6 3.6 0 0 0 6 19z'/>");
    private static readonly MarkupString HorizontalIcon = Svg("<rect x='3' y='5' width='5' height='14' rx='1'/><rect x='10' y='5' width='5' height='14' rx='1' opacity='.7'/><rect x='17' y='5' width='4' height='14' rx='1' opacity='.45'/>");

    private static readonly MarkupString InfiniteIcon = Svg("<path d='M5 9a3 3 0 1 0 0 6c1.6 0 2.6-1.2 3.5-2.5l3-4C15.4 7.2 16.4 6 18 6a3 3 0 1 1 0 6c-1.6 0-2.6-1.2-3.5-2.5'/>");
    private static readonly MarkupString GroupIcon = Svg("<rect x='3' y='3' width='18' height='4' rx='1'/><line x1='6' y1='11' x2='18' y2='11'/><line x1='6' y1='15' x2='18' y2='15'/><line x1='6' y1='19' x2='18' y2='19'/>");
    private static readonly MarkupString ChatIcon = Svg("<path d='M21 12a8 8 0 0 1-11.5 7.2L4 20l1-4.2A8 8 0 1 1 21 12z'/>");

    private static MarkupString Svg(string inner) =>
        new($"<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round' width='18' height='18'>{inner}</svg>");
}
